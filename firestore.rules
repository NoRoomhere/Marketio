rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /influencerProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /brandProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /requests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.brandUid == request.auth.uid || resource.data.influencerUid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.brandUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.brandUid == request.auth.uid || resource.data.influencerUid == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.brandUid == request.auth.uid || resource.data.influencerUid == request.auth.uid);
    }
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null
        && (resource.data.participant1 == request.auth.uid || resource.data.participant2 == request.auth.uid);
      allow create: if request.auth != null
        && (request.resource.data.participant1 == request.auth.uid || request.resource.data.participant2 == request.auth.uid);
    }
    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if request.auth != null
        && (get(/databases/$(database)/documents/chats/$(chatId)).data.participant1 == request.auth.uid
            || get(/databases/$(database)/documents/chats/$(chatId)).data.participant2 == request.auth.uid);
    }
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
